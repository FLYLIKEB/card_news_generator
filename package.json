{
  "name": "card-news-editor",
  "version": "0.1.0",
  "private": true,
  "description": "카드뉴스 에디터 — Claude Code CLI + Electron",
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:compile": "tsc --project tsconfig.electron.json",
    "electron:rebuild": "electron-rebuild -f -w node-pty",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && npm run electron:compile && NODE_ENV=development electron .\"",
    "electron:build": "npm run build && npm run electron:compile && electron-builder",
    "electron:pack": "npm run electron:build -- --dir"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "electron-is-dev": "^3.0.1",
    "jszip": "^3.10.1",
    "next": "16.1.6",
    "node-pty": "^1.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.flylikeb.card-news-editor",
    "productName": "카드뉴스 에디터",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "files": [
      "electron-dist/**",
      "out/**",
      "output/**",
      "node_modules/**",
      "!node_modules/.cache"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "icon": "public/icon.icns"
    },
    "dmg": {
      "title": "카드뉴스 에디터"
    },
    "directories": {
      "buildResources": "public",
      "output": "dist"
    }
  }
}
